# ── Backend ─────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/western_lodge"
PORT=4000
NODE_ENV=development

# Secret header required for GET /api/inquiries (admin use only)
ADMIN_SECRET="change-me-to-something-secret"

# Resend transactional email API key — https://resend.com
RESEND_API_KEY="re_xxxxxxxxxxxxxxxxxxxx"

# Hotel email address for booking notification emails
HOTEL_EMAIL="info@westernhighwaylodge.com"

# Allowed CORS origin (your frontend URL)
CORS_ORIGIN="http://localhost:3000"

# ── Frontend ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL="http://localhost:4000"
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# Optional: Google Maps embed key for the contact section map
NEXT_PUBLIC_GOOGLE_MAPS_EMBED_KEY="YOUR_MAPS_API_KEY"
